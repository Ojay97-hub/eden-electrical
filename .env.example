# Existing app settings
DATABASE_URL="file:./dev.db"
AUTH_SECRET="replace-with-a-long-random-secret"

# Sanity Studio + API
NEXT_PUBLIC_SANITY_PROJECT_ID="wtttxpae"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2025-01-01"

# Server-only token used by /api/contact to create enquiry documents.
# Create this in sanity.io/manage with Editor permissions.
SANITY_API_WRITE_TOKEN="replace-with-sanity-write-token"

# Server-only token that lets the Presentation tool preview DRAFT content live.
# Create this in sanity.io/manage with Viewer (read) permissions.
SANITY_API_READ_TOKEN="replace-with-sanity-read-token"

# Optional email notifications for new contact enquiries
RESEND_API_KEY=""
CONTACT_TO_EMAIL="contact@eden-electrical.com"
